{
  "opening-wake": {
    "category": "story",
    "once": true,
    "trigger": { "type": "wakeUp" },
    "nextTrigger": { "type": "enterMapArea", "stageId": "1-1" },
    "steps": [
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "おーい！大丈夫《だいじょうぶ》かい？"
      },
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "グレート！！気《き》がついたね！君《きみ》の名前《なまえ》は？",
        "nameInput": true
      },
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "{playerName}か、グレートな名前《なまえ》だ！ぼくは フロチャロボ。"
      },
      {
        "bubble": "実《じつ》は、魔物《まもの》たちに ぼくたちの街《まち》が 奪《うば》われてしまったんだ…。"
      },
      {
        "bubble": "街《まち》を 取《と》り戻《もど》すのを 手伝《てつだ》ってくれないか？"
      },
      {
        "choices": [
          { "label": "はい", "goto": "agree" },
          { "label": "いいえ", "goto": "refuse" }
        ]
      },
      {
        "id": "refuse",
        "bubble": "そんなこと 言《い》わずにさあ、たのむよ〜！"
      },
      {
        "choices": [
          { "label": "はい", "goto": "agree" },
          { "label": "いいえ", "goto": "refuse2" }
        ]
      },
      {
        "id": "refuse2",
        "bubble": "たのむ！この通《とお》り！！"
      },
      {
        "choices": [{ "label": "はい", "goto": "agree" }]
      },
      {
        "id": "agree",
        "bubble": "グレート！！！ありがとう！"
      },
      {
        "bubble": "何《なに》を すればいいかは 心配《しんぱい》いらない。ぼくには 力《ちから》が あるんだ。"
      },
      {
        "bubble": "ぼくに カードを はめて 敵《てき》を 倒《たお》すんだ！やり方《かた》は これから 教《おし》えるよ。"
      }
    ]
  },

  "map-stage1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterMapArea", "stageId": "1-1" },
    "steps": [
      { "bubble": "よし、行《い》くぞ {playerName}！" },
      { "bubble": "まずは あの 巻物《まきもの》を押して!", "point": "scroll-1-1" },
      { "point": "scroll-1-1", "waitForArrival": "1-1" }
    ]
  },

  "stage1-1-arrive": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "arriveLandmark", "stageId": "1-1" },
    "steps": [
      { "bubble": "『たたかう』を 押《お》そう!", "point": "fightButton" },
      { "point": "fightButton", "waitForBattle": "1-1" }
    ]
  },

  "stage1-1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-1" },
    "steps": [
      { "bubble": "ここはバトル画面！" },
      { "bubble": "ここが{playerName}のHPで、", "point": "playerHpBar" },
      { "bubble": "ここが相手のHPだよ。", "point": "enemyHpBar" },
      { "bubble": "{playerName}のHPがゼロにならないように敵のHPをゼロにしたら{playerName}の勝ちだ。"},
      { "bubble": "このカードは「攻撃《こうげき》カード」だ！", "point": "attackCard" },
      { "openCardHelp": "attack" },
      { "bubble": "攻撃カードをマスに置いてみよう。"},
      { "bubble": "こうやって マスに 入《い》れてね！", "demoDrag": { "from": "attackCard", "to": "slot-1" }, "waitForCardInSlot": true },
      { "bubble": "ここを押して実行しよう!", "point": "executeButton" }
    ]
  },

  "stage1-1-defeat": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "defeatEnemy", "stageId": "1-1" },
    "steps": [
      { "bubble": "やったね、グレート！" },
      { "bubble": "マップに 戻《もど》って 次《つぎ》へ 進《すす》もうぜ。", "point": "mapBackButton" }
    ]
  },

  "stage1-1-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "1-1" },
    "steps": [
      { "bubble": "次《つぎ》は 1-2 だ。" },
      { "bubble": "{playerName}、ついて こい！", "point": "landmark-1-2" }
    ]
  },

  "stage1-2-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-2" },
    "steps": [
      { "bubble": "この 敵《てき》は こうげきして くるぞ。", "point": "enemyCard" },
      { "bubble": "『ぼうぎょ』カードで 身《み》を 守《まも》れ！", "point": "guardCard" }
    ]
  },

  "stage1-2-lost": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "battleLost", "stageId": "1-2" },
    "steps": [
      { "bubble": "うっ、やられたか…。" },
      { "bubble": "でも へこむな！" },
      { "bubble": "カードを 入《い》れかえれば まだ いける。もう 一度《いちど》だ！", "point": "cardSwap" }
    ]
  },

  "stage1-2-defeat": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "defeatEnemy", "stageId": "1-2" },
    "steps": [
      { "bubble": "グレート！" },
      { "bubble": "その 調子《ちょうし》で どんどん ステージを 進《すす》もう！" }
    ]
  },

  "stage1-3-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-3" },
    "steps": [
      { "bubble": "『かいふく』カードを 見《み》つけたぞ。" },
      { "bubble": "HP が へったら これで 立《た》てなおせる！" }
    ]
  },

  "stage1-4-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-4" },
    "steps": [
      { "bubble": "次《つぎ》は 『カウンター』カードだ。" },
      { "bubble": "敵《てき》の こうげきを はねかえす、たよれる 一枚《いちまい》だぞ。" }
    ]
  },

  "stage1-4-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "1-4" },
    "steps": [
      { "playAnimation": "unlockStage", "params": { "world": "2" } },
      { "bubble": "グレート！ステージ2が 開《ひら》いたぞ！" },
      { "bubble": "次《つぎ》の マップへ 行《い》こう、{playerName}！", "point": "mapButton" }
    ]
  },

  "stage2-3-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "2-3" },
    "steps": [
      { "bubble": "この ステージには 専用《せんよう》の スロットが ある。" },
      { "bubble": "決《き》まった カードしか 入《はい》らないから、よく 見《み》て 使《つか》おう。" }
    ]
  },

  "stage2-4-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "2-4" },
    "steps": [
      { "playAnimation": "unlockStage", "params": { "world": "3" } }
    ]
  },

  "stage3-1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "3-1" },
    "steps": [
      { "bubble": "ここからは 『くりかえし』、for だ。" },
      { "bubble": "同《おな》じ 動《うご》きを 何度《なんど》も じっこう できる。" },
      { "bubble": "グレート だろ？" }
    ]
  },

  "stage4-3-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "4-3" },
    "steps": [
      { "bubble": "『パワーアップ』カードだ。" },
      { "bubble": "これを 使《つか》うと こうげきが もっと 強《つよ》くなるぞ！" }
    ]
  },

  "stage3-4-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "3-4" },
    "steps": [
      { "playAnimation": "unlockStage", "params": { "world": "4" } }
    ]
  }
}
