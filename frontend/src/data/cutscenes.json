{
  "opening-wake": {
    "category": "story",
    "once": true,
    "trigger": { "type": "wakeUp" },
    "nextTrigger": { "type": "enterMapArea", "stageId": "1-1" },
    "steps": [
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "おーい！大丈夫《だいじょうぶ》かい？"
      },
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "グレート！！気《き》がついたね！君《きみ》の名前《なまえ》は？",
        "nameInput": true
      },
      {
        "backdrop": "/story/robo_wakeup.png",
        "bubble": "{playerName}か、グレートな名前《なまえ》だ！ぼくは フロチャロボ。"
      },
      {
        "bubble": "実《じつ》は、魔物《まもの》たちに ぼくたちの街《まち》が 奪《うば》われてしまったんだ…。"
      },
      {
        "bubble": "街《まち》を 取《と》り戻《もど》すのを 手伝《てつだ》ってくれないか？",
        "choices": [
          { "label": "はい", "goto": "agree" },
          { "label": "いいえ", "goto": "refuse" }
        ]
      },
      {
        "id": "refuse",
        "bubble": "そんなこと 言《い》わずにさあ、たのむよ〜！",
        "choices": [
          { "label": "はい", "goto": "agree" },
          { "label": "いいえ", "goto": "refuse2" }
        ]
      },
      {
        "id": "refuse2",
        "bubble": "たのむ！この通《とお》り！！",
        "choices": [{ "label": "はい", "goto": "agree" }]
      },
      {
        "id": "agree",
        "bubble": "グレート！！！ありがとう！"
      },
      {
        "bubble": "何《なに》を すればいいかは 心配《しんぱい》いらない。ぼくには 力《ちから》が あるんだ。"
      },
      {
        "bubble": "ぼくに カードを はめて 敵《てき》を 倒《たお》すんだ！やり方《かた》は これから 教《おし》えるよ。"
      }
    ]
  },

  "map-stage1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterMapArea", "stageId": "1-1" },
    "steps": [
      { "bubble": "よし、行《い》くぞ {playerName}！" },
      { "bubble": "まずは あの 巻物《まきもの》を押して!", "point": "scroll-1-1" },
      { "point": "scroll-1-1", "waitForArrival": "1-1" }
    ]
  },

  "stage1-1-arrive": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "arriveLandmark", "stageId": "1-1" },
    "steps": [
      { "bubble": "『たたかう』を 押《お》そう!", "point": "fightButton" },
      { "point": "fightButton", "waitForBattle": "1-1" }
    ]
  },

  "stage1-1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-1" },
    "steps": [
      { "bubble": "ここはバトル画面！" },
      { "bubble": "ここが{playerName}のHPで、", "point": "playerHpBar" },
      { "bubble": "ここが相手のHPだよ。", "point": "enemyHpBar" },
      { "bubble": "{playerName}のHPがゼロにならないように敵のHPをゼロにしたら{playerName}の勝ちだ。"},
      { "bubble": "このカードは「攻撃《こうげき》カード」だ！", "point": "attackCard" },
      { "openCardHelp": "attack" },
      { "bubble": "攻撃カードをマスに置いてみよう。"},
      { "bubble": "こうやって マスに 入《い》れてね！", "demoDrag": { "from": "attackCard", "to": "slot-1" }, "waitForCardInSlot": true },
      { "bubble": "ここを押して実行しよう!", "point": "executeButton", "waitForExecute": true }
    ]
  },

  "stage1-1-defeat": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "defeatEnemy", "stageId": "1-1" },
    "steps": [
      { "bubble": "やったね、グレート！" },
      { "bubble": "マップに 戻《もど》って 次《つぎ》へ 進《すす》もうぜ。", "point": "mapBackButton" }
    ]
  },

  "stage1-1-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "1-1" },
    "steps": [
      { "bubble": "次《つぎ》は 1-2 だ！{playerName}、ついてこい！", "point": "scroll-1-2" }
    ]
  },

  "stage1-2-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-2" },
    "steps": [
      { "bubble": "この敵《てき》は 攻撃《こうげき》してくるぞ！", "point": "slot-2" },
      { "bubble": "「防御《ぼうぎょ》カード」で 身《み》を 守《まも》るんだ！", "point": "guardCard" },
      { "openCardHelp": "monster" },
      { "openCardHelp": "guard" }
    ]
  },

  "stage1-3-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-3" },
    "steps": [
      { "bubble": "敵《てき》の 攻撃《こうげき》を 2回《かい》 受《う》けてしまうと、{playerName}の HPが 0に なってしまう。これは グレートじゃない…" },
      { "bubble": "そんな時《とき》は 「回復《かいふく》カード」を 使《つか》おう！", "point": "healCard" },
      { "openCardHelp": "heal" }
    ]
  },

  "stage1-4-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "1-4" },
    "steps": [
      { "bubble": "このカードは 「カウンターカード」！", "point": "reflectCard" },
      { "bubble": "敵《てき》の 攻撃《こうげき》を 跳《は》ね返《かえ》すことが できるぞ！" },
      { "openCardHelp": "reflect" }
    ]
  },

  "stage1-4-defeat": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "defeatEnemy", "stageId": "1-4" },
    "steps": [
      { "bubble": "超絶《ちょうぜつ》グレート！！" },
      { "bubble": "ステージ1 クリアだ！" }
    ]
  },

  "stage1-4-exit": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "exitStage", "stageId": "1-4" },
    "steps": [
      { "bubble": "ここを 押《お》して ステージ2に 進《すす》もう！", "point": "mapButton" }
    ]
  },

  "map-stage2-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterMapArea", "stageId": "2-1" },
    "steps": [
      { "bubble": "ここからの 敵《てき》は 手強《てごわ》いぞ！" }
    ]
  },

  "stage2-3-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "2-3" },
    "steps": [
      { "bubble": "このマスは 「種類指定《しゅるいしてい》マス」！", "point": "slot-3" },
      { "bubble": "回復《かいふく》カードしか 当《あ》てはめられないぞ！", "point": "slot-3" },
      { "bubble": "このマスは 「倍率《ばいりつ》マス」！", "point": "slot-7" },
      { "bubble": "カードの 効果《こうか》が 書《か》かれている 数字倍《すうじばい》されるぞ！", "point": "slot-7" },
      { "openSlotHelp": "acceptOnly" },
      { "openSlotHelp": "multiplier" }
    ]
  },

  "stage2-4-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "2-4" },
    "steps": [
      { "bubble": "ステージ2の ボスだ！強敵《きょうてき》だが、君《きみ》なら できる！" }
    ]
  },

  "stage2-4-defeat": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "defeatEnemy", "stageId": "2-4" },
    "steps": [
      { "bubble": "超絶《ちょうぜつ》グレート！！" }
    ]
  },

  "stage3-1-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "3-1" },
    "steps": [
      { "bubble": "これは 「条件《じょうけん》マス」！", "point": "cond-1" },
      { "bubble": "マスに 書《か》いてある 質問《しつもん》の 答《こた》えによって 進《すす》む道《みち》が 変《か》わるぞ！", "point": "cond-1" },
      { "openSlotHelp": "condition" }
    ]
  },

  "stage3-4-enter": {
    "category": "tutorial",
    "once": true,
    "trigger": { "type": "enterBattle", "stageId": "3-4" },
    "steps": [
      { "bubble": "ここを 突破《とっぱ》できれば、魔物《まもの》たちの ボスがいる ステージに 行《い》ける！" },
      { "bubble": "ぼくと 力《ちから》を 合《あ》わせて 倒《たお》そう！！" }
    ]
  }
}
